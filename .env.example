# ── Bybit API ──────────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# ── Trading ─────────────────────────────────────────────────────────────────
# Символ в формате ccxt spot: BTC/USDT, ETH/USDT, SOL/USDT и т.д.
TRADING_SYMBOL=BTC/USDT
# Таймфрейм ccxt: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=15m
INITIAL_BALANCE=10000.0
RISK_PER_TRADE=0.02
COMMISSION_RATE=0.001
# Интервал цикла в секундах (30 = режим реального времени)
TRADING_INTERVAL=30
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENT=0.05

# ── AI (Claude API) ─────────────────────────────────────────────────────────
# Ключ Anthropic — получить на https://console.anthropic.com
ANTHROPIC_API_KEY=
# Модель Claude для анализа рынка
AI_MODEL=claude-sonnet-4-6

# ── Режим работы ─────────────────────────────────────────────────────────────
# local   → только правила (9 стратегий), без внешних API
# dqn     → только SAC-модель (обученная)
# ai      → только Claude API (по умолчанию)
# hybrid  → SAC + Claude должны согласиться; расхождение → hold
MODE=ai
# SAC модель (создаётся: python reinforcement_learning/train_sac.py)
SAC_MODEL_PATH=models/sac_model.zip

# ── Market Scanner ──────────────────────────────────────────────────────────
# Сколько топ монет сканировать за итерацию (по объёму за 24ч)
SCAN_TOP_N=20
# true — автоматически исполнять топ-1 рекомендацию (осторожно!)
AUTO_EXECUTE=false

# ── Стратегии ───────────────────────────────────────────────────────────────
# Доступные стратегии:
#   ema_crossover   — EMA 12/26 кроссовер       (medium risk, trending)
#   rsi_momentum    — RSI перекупл./перепродан.  (medium risk, ranging)
#   macd_crossover  — MACD/Signal кроссовер      (medium risk, trending)
#   bollinger_bands — Полосы Боллинджера + RSI   (medium risk, volatile)
#   scalping        — Быстрые сделки <15m        (high risk,   volatile)
#   swing_trading   — Свинг на поворотах тренда  (medium risk, trending)
#   breakout        — Пробой уровней + объём     (high risk,   volatile)
#   mean_reversion  — Возврат к среднему         (medium risk, ranging)
#   trend_following — Следование тренду SMA50    (low risk,    trending)
ACTIVE_STRATEGY=ema_crossover

# true — AI (Claude) выбирает стратегию автоматически
AI_STRATEGY_SELECTION=false

# Минимальный confidence сигнала для исполнения (0.0–1.0)
MIN_SIGNAL_CONFIDENCE=0.65

# ── News API ─────────────────────────────────────────────────────────────────
# Ключ NewsAPI — получить на https://newsapi.org
NEWS_API_KEY=
# Интервал обновления новостей в секундах (900 = 15 мин)
NEWS_UPDATE_INTERVAL=900

# ── Telegram ──────────────────────────────────────────────────────────────
# Токен от BotFather (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
# Ваш chat_id (узнать: @userinfobot)
TELEGRAM_CHAT_ID=
# Секунд ждать ответа перед авто-исполнением (Вариант B)
TELEGRAM_CONFIRM_TIMEOUT=60

# ── Position Management ───────────────────────────────────────────────────
# Максимум одновременных позиций (защита от overfitting)
MAX_POSITIONS=3
# true → бумажная торговля (нет реальных ордеров)
PAPER_TRADING=true
# Trailing SL: двигать стоп вслед за ценой (множитель ATR)
TRAILING_STOP_ATR_MULT=1.0
