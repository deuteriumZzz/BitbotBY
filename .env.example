# =============================================================================
# BitbotBY — конфигурация торгового бота
# Скопируйте в .env и заполните свои ключи
# =============================================================================

# ── Bybit API ─────────────────────────────────────────────────────────────────
# Получить на: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# ── AI (Claude API) ───────────────────────────────────────────────────────────
# Получить на: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Модель Claude для анализа рынка
AI_MODEL=claude-sonnet-4-6

# ── Telegram (обязательно для подтверждений) ──────────────────────────────────
# 1. Написать @BotFather → /newbot → скопировать токен
TELEGRAM_BOT_TOKEN=
# 2. Написать @userinfobot → скопировать ваш id
TELEGRAM_CHAT_ID=
# Секунд ждать ответа перед авто-исполнением (Вариант B)
TELEGRAM_CONFIRM_TIMEOUT=60

# ── News API (опционально, улучшает качество сигналов) ───────────────────────
# Получить на: https://newsapi.org
NEWS_API_KEY=
# Интервал обновления новостей в секундах (900 = 15 мин)
NEWS_UPDATE_INTERVAL=900

# ── Режим работы ──────────────────────────────────────────────────────────────
# ai     → Claude AI выбирает стратегию и монету (рекомендуется)
# hybrid → DQN + Claude должны согласиться; расхождение → hold
# dqn    → только обученная DQN-модель (нужен train_dqn.py)
# local  → только правила (9 стратегий), без внешних API
MODE=ai

# ── Торговля ──────────────────────────────────────────────────────────────────
# Основной символ (используется если AI_STRATEGY_SELECTION=false)
TRADING_SYMBOL=BTC/USDT
# Таймфрейм: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=15m
# Начальный баланс для расчётов (берётся из биржи при старте)
INITIAL_BALANCE=10000.0
# Риск на сделку — доля баланса (0.02 = 2%)
RISK_PER_TRADE=0.02
# Комиссия биржи (Bybit taker = 0.001 = 0.1%)
COMMISSION_RATE=0.001
# Интервал цикла в секундах (30 = режим реального времени)
TRADING_INTERVAL=30
# Максимальный размер позиции — доля баланса (0.1 = 10%)
MAX_POSITION_SIZE=0.1
# Стоп-лосс по умолчанию если нет ATR (5%)
STOP_LOSS_PERCENT=0.05

# ── Market Scanner ────────────────────────────────────────────────────────────
# Сколько топ монет сканировать за итерацию (по объёму за 24ч)
SCAN_TOP_N=20
# true — автоматически исполнять сделки + спрашивать в Telegram
# false — только показывать рекомендации в консоли (безопасный режим)
AUTO_EXECUTE=false

# ── Стратегии ─────────────────────────────────────────────────────────────────
# Доступные стратегии (ACTIVE_STRATEGY используется только как фолбэк):
#   ema_crossover   — EMA 12/26 кроссовер       (medium risk, trending)
#   rsi_momentum    — RSI перекупл./перепродан.  (medium risk, ranging)
#   macd_crossover  — MACD/Signal кроссовер      (medium risk, trending)
#   bollinger_bands — Полосы Боллинджера + RSI   (medium risk, volatile)
#   scalping        — Быстрые сделки <15m        (high risk,   volatile)
#   swing_trading   — Свинг на поворотах тренда  (medium risk, trending)
#   breakout        — Пробой уровней + объём     (high risk,   volatile)
#   mean_reversion  — Возврат к среднему         (medium risk, ranging)
#   trend_following — Следование тренду SMA50    (low risk,    trending)
# Фолбэк-стратегия (когда AI_STRATEGY_SELECTION=false или нет ANTHROPIC_API_KEY)
ACTIVE_STRATEGY=ema_crossover

# true — Claude AI сам выбирает лучшую стратегию для каждой монеты
# РЕКОМЕНДУЕТСЯ: включить вместе с MODE=ai
AI_STRATEGY_SELECTION=true

# Минимальный confidence сигнала для исполнения (0.0–1.0)
# Сигналы ниже порога игнорируются
MIN_SIGNAL_CONFIDENCE=0.65

# ── Управление позициями ──────────────────────────────────────────────────────
# Максимум одновременных открытых позиций
MAX_POSITIONS=3
# true → бумажная торговля (нет реальных ордеров, безопасно для теста)
PAPER_TRADING=true
# Trailing SL: сдвигать стоп вслед за ценой (множитель ATR, 0 = выключено)
TRAILING_STOP_ATR_MULT=1.0

# ── Риск-менеджмент ───────────────────────────────────────────────────────────
# Максимальный дневной убыток — доля баланса (0.05 = 5%, потом бот стоп)
DAILY_LOSS_LIMIT=0.05
# true → использовать Bybit testnet (для тестирования без реальных денег)
TESTNET=false

# ── DQN (только для MODE=dqn или MODE=hybrid) ─────────────────────────────────
# Путь к файлу весов DQN (создаётся командой: python train_dqn.py)
DQN_MODEL_PATH=models/dqn_model.pth
