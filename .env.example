# ── Bybit API ──────────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
# true → торговать на testnet (без реальных денег)
TESTNET=false

# Тип рынка:
# "spot"   — только лонги, не может шортить
# "linear" — perpetual futures, полный long+short (рекомендуется)
MARKET_TYPE=linear

# Плечо для фьючерсов (1=без плеча, рекомендуется 2-3x для старта)
LEVERAGE=3
# Режим управления плечом:
#   fixed      — всегда LEVERAGE (простой)
#   volatility — ATR-таргетинг: авто-подбор под волатильность [рекомендуется]
#   full       — ATR + режим рынка (up/sideways/down) + просадка
LEVERAGE_MODE=volatility
# Целевой риск портфеля на одно ATR-движение (0.01 = 1%); fallback = LEVERAGE
LEVERAGE_TARGET_RISK=0.01
LEVERAGE_MAX=5
LEVERAGE_MIN=1
# Порог просадки для режима плеча "full":
# при достижении этой просадки плечо снижается до 30% от расчётного.
# 0.10 = агрессивная защита, 0.15 = умеренная (рекомендуется), 0.20 = мягкая
MAX_DRAWDOWN_PERCENT=0.15

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
# Пароль Redis — рекомендуется задать в production (docker-compose передаст его
# в redis-server автоматически через --requirepass)
REDIS_PASSWORD=

# ── Dashboard auth ──────────────────────────────────────────────────────────
# После изменения запустить: make htpasswd
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ── Trading ─────────────────────────────────────────────────────────────────
# Символ в формате ccxt spot: BTC/USDT, ETH/USDT, SOL/USDT и т.д.
TRADING_SYMBOL=BTC/USDT
# Таймфрейм ccxt: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=15m
INITIAL_BALANCE=10000.0
RISK_PER_TRADE=0.02
COMMISSION_RATE=0.001
# Интервал цикла в секундах (30 = режим реального времени)
TRADING_INTERVAL=30
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENT=0.05

# ── AI провайдер ────────────────────────────────────────────────────────────
# Какой AI использовать для анализа рынка и сентимента новостей.
# Порядок fallback при auto: Claude → OpenAI → DeepSeek → Groq → локальные стратегии
#   auto      → первый найденный ключ в порядке выше
#   anthropic → только Claude (лучшее качество)
#   openai    → только ChatGPT
#   deepseek  → только DeepSeek (самый дешёвый)
#   groq      → только Groq / Llama 3.3 70B (БЕСПЛАТНЫЙ тир, самый быстрый)
AI_PROVIDER=auto

# ★ Groq — БЕСПЛАТНЫЙ тир, самый быстрый, Llama 3.3 70B
# Получить ключ: https://console.groq.com → API Keys → Create
# Рекомендуется для старта — не нужна кредитная карта
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ★ Google Gemini Flash — БЕСПЛАТНЫЙ тир, 1500 запросов/день
# Получить ключ: https://aistudio.google.com → Get API Key
# Резервный провайдер после Groq
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Claude (Anthropic) — лучшее качество анализа
# Получить ключ: https://console.anthropic.com
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# DeepSeek — самый дешёвый платный (~$0.002/запрос, в 10x дешевле Claude)
# Получить ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ChatGPT (OpenAI)
# Получить ключ: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Лимит AI-вызовов в сутки (UTC) для всех провайдеров; сверх → VADER-фолбек
# CLAUDE_DAILY_BUDGET принимается как алиас (обратная совместимость)
AI_DAILY_BUDGET=200

# ── Режим работы ─────────────────────────────────────────────────────────────
# local   → только правила (9 стратегий), без внешних API
# dqn     → только SAC-модель (обученная)
# ai      → AI-провайдер (по умолчанию)
# hybrid  → SAC + AI должны согласиться; расхождение → hold
MODE=ai
# SAC модель (создаётся: python reinforcement_learning/train_sac.py)
SAC_MODEL_PATH=models/sac_model.zip

# ── Signal Combiner (hybrid режим) ──────────────────────────────────────────
# Веса сигналов SAC и AI (сумма = 1.0)
DQN_WEIGHT=0.4
AI_WEIGHT=0.6
# Минимальный confidence SAC для соло-исполнения без AI
DQN_SOLO_CONFIDENCE=0.80

# ── Market Scanner ──────────────────────────────────────────────────────────
# Сколько топ монет сканировать за итерацию (по объёму за 24ч)
SCAN_TOP_N=20
# true — автоматически исполнять топ-1 рекомендацию (осторожно!)
AUTO_EXECUTE=false

# ── Стратегии ───────────────────────────────────────────────────────────────
# Доступные стратегии:
#   ema_crossover   — EMA 12/26 кроссовер       (medium risk, trending)
#   rsi_momentum    — RSI перекупл./перепродан.  (medium risk, ranging)
#   macd_crossover  — MACD/Signal кроссовер      (medium risk, trending)
#   bollinger_bands — Полосы Боллинджера + RSI   (medium risk, volatile)
#   scalping        — Быстрые сделки <15m        (high risk,   volatile)
#   swing_trading   — Свинг на поворотах тренда  (medium risk, trending)
#   breakout        — Пробой уровней + объём     (high risk,   volatile)
#   mean_reversion  — Возврат к среднему         (medium risk, ranging)
#   trend_following — Следование тренду SMA50    (low risk,    trending)
ACTIVE_STRATEGY=ema_crossover

# true — AI выбирает стратегию автоматически
AI_STRATEGY_SELECTION=false

# Минимальный confidence сигнала для исполнения (0.0–1.0)
MIN_SIGNAL_CONFIDENCE=0.65

# ── News API ─────────────────────────────────────────────────────────────────
# Ключ NewsAPI — получить на https://newsapi.org
NEWS_API_KEY=
# Интервал обновления новостей в секундах (900 = 15 мин)
NEWS_UPDATE_INTERVAL=900

# ── Telegram ──────────────────────────────────────────────────────────────
# Токен от BotFather (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
# Ваш chat_id (узнать: @userinfobot)
TELEGRAM_CHAT_ID=
# Секунд ждать ответа перед авто-исполнением
TELEGRAM_CONFIRM_TIMEOUT=60

# ── Risk Management ───────────────────────────────────────────────────────
# Максимальный дневной убыток: доля баланса (0.05 = 5%); сверх → стоп торговли
DAILY_LOSS_LIMIT=0.05

# ── Position Management ───────────────────────────────────────────────────
# Максимум одновременных позиций
MAX_POSITIONS=3
# true → бумажная торговля (нет реальных ордеров)
PAPER_TRADING=true
# Кодовое слово для переключения Paper ↔ Live через Telegram
# (оставить пустым — переключение по кнопке без PIN)
TRADING_MODE_PIN=

# ── Season Detector ───────────────────────────────────────────────────────────
# Режим реакции на смену сезона (только в LIVE режиме):
#   alert — уведомление в Telegram с кнопками Переключить / Оставить (рекомендуется)
#   auto  — профиль переключается автоматически без подтверждения
SEASON_SWITCH_MODE=alert
# Интервал проверки CoinGecko в часах (бесплатный API, ключи не нужны)
SEASON_CHECK_INTERVAL_H=4
# Trailing SL: двигать стоп вслед за ценой (множитель ATR)
TRAILING_STOP_ATR_MULT=1.0
# Circuit breaker: остановить бота после N подряд убыточных сделок (0 = выключен)
CIRCUIT_BREAKER_LOSSES=3

# ── Monitoring ────────────────────────────────────────────────────────────
# Порт HTTP health-сервера (GET /health → JSON, GET /metrics → Prometheus)
# 0 = выключен
HEALTH_PORT=8080
# API-ключ для дашборда (опционально). Если задан, все запросы кроме
# /health и /metrics требуют заголовок: X-API-Key: <значение>
DASHBOARD_API_KEY=
# Shared secret для вебхука Alertmanager (опционально). Если задан,
# Alertmanager должен слать заголовок X-Webhook-Secret: <значение>
ALERTMANAGER_WEBHOOK_SECRET=
# Максимальные часы молчания бота до "silent death" алерта
SILENT_DEATH_HOURS=6.0
# TTL кэша режима рынка в секундах
REGIME_CACHE_TTL=300

# ── Correlation filter ────────────────────────────────────────────────────
# Максимальная |корреляция| log-returns между одновременными позициями.
# Если новый сигнал коррелирует с любой открытой позицией сильнее порога —
# сигнал пропускается (защита от удвоенной экспозиции, напр. BTC + ETH лонг).
# 0.0 = фильтр выключен; рекомендовано 0.7
MAX_CORRELATION=0.7
# Окно расчёта корреляции в свечах (минимум 10)
CORRELATION_WINDOW=50

# ── Partial TP (улучшение 3) ─────────────────────────────────────────────
# true → закрывать часть позиции при достижении PARTIAL_TP_TRIGGER пути до TP
PARTIAL_TP_ENABLED=true
# Доля пути до TP для срабатывания (0.6 = 60%)
PARTIAL_TP_TRIGGER=0.6
# Доля позиции для закрытия (0.5 = 50%)
PARTIAL_TP_FRACTION=0.5

# ── Trading hours filter (улучшение 4) ───────────────────────────────────
# Торговые часы UTC. Пример: "8-22" = только с 8:00 до 22:00 UTC.
# Пустая строка = круглосуточно (по умолчанию).
TRADING_HOURS=

# ── Liquidity filter (улучшение 5) ───────────────────────────────────────
# Минимальный 24h объём в USDT для допуска к торговле
MIN_VOLUME_USDT=1000000
# Максимальный 24h объём в USDT (0 = без ограничения).
# Для профиля Альткоины: 2000000000 (отсекает BTC/ETH/SOL).
MAX_VOLUME_USDT=0
# Максимальный допустимый спред bid/ask в процентах (0.3 = 0.3%)
MAX_SPREAD_PCT=0.3
# Volume spike: во сколько раз объём свечи должен превысить среднее за 20 свечей.
# 2.5 = аномалия. Используется стратегией volume_spike. Диапазон: 2.0–4.0.
VOLUME_SPIKE_THRESHOLD=2.5

# ── Drawdown scaling (улучшение 6) ───────────────────────────────────────
# true → уменьшать размер позиции при просадке от пика баланса
DRAWDOWN_SCALE_ENABLED=true
# Порог просадки для активации (0.10 = 10% от пика)
DRAWDOWN_SCALE_THRESHOLD=0.10
# Множитель размера позиции при просадке (0.5 = уменьшить до 50%)
DRAWDOWN_SCALE_FACTOR=0.5

# ── Backtest ──────────────────────────────────────────────────────────────
# Доля данных для out-of-sample теста (0.2 = последние 20% данных)
BT_HOLDOUT_RATIO=0.2

# ── Macro blackout (улучшение 7) ─────────────────────────────────────────
# Ключ Finnhub API (бесплатный тир): https://finnhub.io
# Если не задан — фильтр отключается автоматически.
FINNHUB_API_KEY=
# true → блокировать открытие позиций за 30 мин до/после FOMC/CPI/NFP/GDP/PCE
MACRO_BLACKOUT_ENABLED=true

# ── Online Learning ────────────────────────────────────────────────────────
# Автообучение SAC-модели на реальных сделках.
#
# Режимы:
#   disabled — выключено, вручную: make train
#   online   — gradient steps после каждой сделки [⚠ РИСКОВАННО, только эксперименты]
#   periodic — полное переобучение в фоне каждые N сделок [✅ РЕКОМЕНДУЕТСЯ]
#   hybrid   — periodic + динамические веса стратегий в реальном времени
#              (рекомендуется после 200+ сделок)
#
# Путь перехода: накопить 100+ сделок → periodic → после 500+ сделок → hybrid
ONLINE_LEARNING_MODE=periodic

# Количество закрытых сделок до запуска переобучения (для periodic/hybrid)
ONLINE_LEARNING_TRIGGER=50

# Шагов градиента за один online-апдейт (только для режима online, ≤ 50)
ONLINE_LEARNING_GRADIENT_STEPS=50

# ── SAC Training ──────────────────────────────────────────────────────────
TRAIN_TOP_N=20
TRAIN_MIN_CANDLES=2880
TOTAL_TIMESTEPS=50000

# Пути к данным разделены по профилям — каждый профиль хранит свои данные отдельно.
# SAC_PROFILE выставляется автоматически при смене профиля через Telegram.
# Задавать вручную не нужно — бот управляет этим сам.
#
# Итоговые пути при активном профиле:
#   bluechip → data/experiences_bluechip.jsonl, models/best_hyperparams_bluechip.json
#   altcoin  → data/experiences_altcoin.jsonl,  models/best_hyperparams_altcoin.json
SAC_PROFILE=

# Используется только если SAC_PROFILE не задан (legacy / ручной запуск).
EXPERIENCES_PATH=data/experiences.jsonl
EXPERIENCES_MAX=10000

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
JSON_LOGS=false
